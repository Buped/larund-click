# ==============================================================================
# Larund Click — environment template
#
# This file holds APP-LEVEL DEVELOPER CREDENTIALS ONLY.
#
#   • App-level credentials (OAuth client id/secret, redirect URI, MCP URLs)
#     belong to Larund the application. You, the developer, configure them once.
#     They let every user START a connection flow.
#
#   • USER tokens (access/refresh tokens, selected accounts, workspace IDs) are
#     created when a user clicks "Connect" and are stored encrypted, per user, in
#     the ConnectedAccount store — NEVER in this file.
#
# See docs/connections/credentials-architecture.md for the full model.
# Copy to `.env` (or run `npm run env:sync`) and fill in the values you have.
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# Larund core
# ──────────────────────────────────────────────────────────────────────────────
LARUND_ENV=development
LARUND_APP_URL=http://localhost:1420
LARUND_API_URL=http://localhost:1420
LARUND_CONNECTIONS_STRICT=true
LARUND_ALLOW_MOCK_CONNECTIONS=false
LARUND_ENABLE_DEV_PAT_SHORTCUTS=false
# local_dev: token exchange uses the client secrets below (developer testing only).
# backend:   desktop opens the browser, a Larund backend performs token exchange.
LARUND_AUTH_EXCHANGE_MODE=local_dev
# Desktop loopback redirect. Every provider uses this SAME value — register it
# (exactly, with the trailing slash: http://localhost:14200/) in each provider's
# OAuth console. No per-provider redirect keys needed.
LARUND_OAUTH_CALLBACK_BASE=http://localhost:14200

# Optional app services (Larund's own infra, not user connections)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_OPENROUTER_API_KEY=

# Each OAuth provider needs only its app-level CLIENT_ID/SECRET (set once by the
# developer). End users connect with one click; their tokens never live here.

# ──────────────────────────────────────────────────────────────────────────────
# Google OAuth app — one client powers Drive, Docs, Sheets, Gmail, Calendar.
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# GitHub OAuth app
# ──────────────────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Notion public integration / OAuth app
# ──────────────────────────────────────────────────────────────────────────────
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Slack OAuth app
# ──────────────────────────────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# X / Twitter OAuth app (OAuth 2.0 Authorization Code + PKCE)
# X_CLIENT_SECRET only needed for confidential / backend exchange mode.
# X_APP_BEARER enables app-only public search/read for users who have not connected X.
# ──────────────────────────────────────────────────────────────────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
X_APP_BEARER=

# ──────────────────────────────────────────────────────────────────────────────
# Meta app (Facebook / Instagram / Ads)
# ──────────────────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Microsoft OAuth app
# ──────────────────────────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ──────────────────────────────────────────────────────────────────────────────
# Discord app
# ──────────────────────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# MCP provider URLs — default connector endpoints, not user tokens.
# Users can override/add a custom MCP server in the app.
# ──────────────────────────────────────────────────────────────────────────────
HIGGSFIELD_MCP_URL=
CANVA_MCP_URL=
FIGMA_MCP_URL=
LINEAR_MCP_URL=
SUPABASE_MCP_URL=
VERCEL_MCP_URL=

# ==============================================================================
# Developer-only local PAT shortcuts
#
# Single-developer testing ONLY. NOT the production connection model and NOT
# multi-user. Enabled only when LARUND_ENABLE_DEV_PAT_SHORTCUTS=true; otherwise
# the runtime ignores them entirely. They are surfaced only in Developer Mode and
# must never be used for another user's account.
#
# `npm run env:sync` does NOT write these unless you pass --include-dev-shortcuts
# (npm run env:sync:dev-shortcuts).
# ==============================================================================
DEV_GITHUB_TOKEN=
DEV_NOTION_TOKEN=
DEV_SLACK_BOT_TOKEN=
DEV_DISCORD_BOT_TOKEN=
DEV_X_BEARER_TOKEN=
DEV_X_WRITE_ACCESS_TOKEN=
DEV_X_WRITE_ACCESS_TOKEN_SECRET=
DEV_AIRTABLE_TOKEN=
DEV_LINEAR_API_KEY=
DEV_HUBSPOT_PRIVATE_APP_TOKEN=
DEV_WORDPRESS_SITE_URL=
DEV_WORDPRESS_USERNAME=
DEV_WORDPRESS_APP_PASSWORD=
DEV_RESEND_API_KEY=
DEV_SENDGRID_API_KEY=
DEV_SUPABASE_URL=
DEV_SUPABASE_SERVICE_ROLE_KEY=
DEV_VERCEL_TOKEN=
DEV_STRIPE_SECRET_KEY=
