{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "oauth:allow-start",
    "oauth:allow-cancel",
    "store:default",
    "dialog:default",
    "dialog:allow-open",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load"
  ]
}
